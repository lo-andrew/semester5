<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.senecacollege.application.controllers.MainController">

    <left>
        <VBox prefHeight="674.0" prefWidth="94.0" spacing="10" BorderPane.alignment="CENTER_LEFT">
            <children>
                <Button onAction="#handleOnPressBtn1" text="Scene 1" />
                <Button onAction="#handleOnPressBtn2" text="Scene 2" />
                <Button onAction="#handleOnPressBtn3" text="Scene 3" />
            </children>
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
        </VBox>
    </left>

    <center>
        <Label style="-fx-font-size: 32px;" text="Main View" />
    </center>

    <bottom>
        <ButtonBar>
            <buttons>
                <Button onAction="#handleClose" text="Close" />
            </buttons>
         <padding>
            <Insets bottom="15.0" right="15.0" />
         </padding>
        </ButtonBar>
    </bottom>
</BorderPane>
