<BorderPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.senecacollege.application.controllers.ViewThreeController">

    <center>
        <Label style="-fx-font-size: 32px;" text="This is Scene 3" />
    </center>

    <bottom>
        <ButtonBar>
            <buttons>
                <Button onAction="#handleBack" text="Back" />
                <Button onAction="#handleClose" text="Close" />
