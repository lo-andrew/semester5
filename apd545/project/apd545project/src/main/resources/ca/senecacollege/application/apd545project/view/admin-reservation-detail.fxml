<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root" prefHeight="650.0" prefWidth="700.0" spacing="14.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.senecacollege.application.apd545project.controller.AdminController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="reservationIdLabel" text="Reservation #0000" />

    <HBox spacing="10.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Guest Name" />
            <TextField fx:id="guestNameField" />
        </VBox>
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Phone" />
            <TextField fx:id="guestPhoneField" />
        </VBox>
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Email" />
            <TextField fx:id="guestEmailField" />
        </VBox>
    </HBox>

    <HBox spacing="10.0">
        <VBox spacing="4.0">
            <Label text="Check-In" />
            <DatePicker fx:id="checkInPicker" />
        </VBox>
        <VBox spacing="4.0">
            <Label text="Check-Out" />
            <DatePicker fx:id="checkOutPicker" />
        </VBox>
        <VBox spacing="4.0">
            <Label text="Status" />
            <ComboBox fx:id="statusComboBox" />
        </VBox>
    </HBox>

    <Label text="Rooms" />
    <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="roomNumberColumn" prefWidth="90.0" text="Room #" />
            <TableColumn fx:id="roomTypeColumn" prefWidth="110.0" text="Type" />
            <TableColumn fx:id="occupancyColumn" prefWidth="90.0" text="Occupancy" />
            <TableColumn fx:id="roomPriceColumn" prefWidth="100.0" text="Price/Night" />
        </columns>
    </TableView>

    <HBox spacing="10.0">
        <Button onAction="#onAddRoom" text="Add Room" />
        <Button onAction="#onRemoveRoom" text="Remove Room" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Discount %" />
        <TextField fx:id="discountField" prefWidth="80.0" />
        <Button onAction="#onApplyDiscount" text="Apply Discount" />
    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#onCancelReservation" text="Cancel Reservation" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onOpenPayment" text="Process Payment" />
        <Button onAction="#onOpenCheckout" text="Checkout" />
        <Button onAction="#onSaveReservation" text="Save Changes" />
        <Button cancelButton="true" onAction="#onClose" text="Close" />
    </HBox>

</VBox>
