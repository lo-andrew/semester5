<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="root" prefHeight="600.0" prefWidth="960.0" style="-fx-background-color: #F5F5F5;"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ca.senecacollege.application.apd545project.controller.KioskController">

    <left>
        <VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="143.0" spacing="20.0"
              style="-fx-background-color: #1B3A57;">
            <padding>
                <Insets bottom="30.0" left="15.0" right="15.0" top="30.0"/>
            </padding>
            <Button fx:id="rulesButton" maxHeight="-Infinity" maxWidth="-Infinity"
                    minHeight="-Infinity" minWidth="-Infinity"
                    onAction="#onViewRules" prefHeight="25.0" prefWidth="125.0"
                    text="Rules &amp; Regulations" wrapText="true">
                <font>
                    <Font size="10.0"/>
                </font>
            </Button>
        </VBox>
    </left>

    <center>
        <!-- swapped at runtime by KioskShellController.showStep() -->
    </center>

</BorderPane>
