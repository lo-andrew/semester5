<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
    </padding>

    <Label text="Add-on Services">
      <font>
         <Font name="System Bold" size="27.0" />
      </font></Label>

    <Label style="-fx-font-size: 14px; -fx-text-fill: #555555;" text="Select any additional services for your stay." />

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <CheckBox fx:id="wifiCheck" onAction="#onAddonToggled" text="Wi-Fi" />
        <Label text="+$9.99 / night" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <CheckBox fx:id="breakfastCheck" onAction="#onAddonToggled" text="Breakfast" />
        <Label text="+$19.99 / night" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <CheckBox fx:id="parkingCheck" onAction="#onAddonToggled" text="Parking" />
        <Label text="+$14.99 / night" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <CheckBox fx:id="spaCheck" onAction="#onAddonToggled" text="Spa" />
        <Label text="+$49.99 / reservation" />
    </HBox>

    <Label fx:id="addonsTotalLabel" style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Add-ons Total: $0.00" />

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button alignment="CENTER" onAction="#onAddonsBack" prefHeight="40.0" prefWidth="90.0" text="Back" />
        <Button defaultButton="true" onAction="#onAddonsNext" prefHeight="40.0" prefWidth="90.0" styleClass="next-btn" text="Next" />
    </HBox>
</VBox>
