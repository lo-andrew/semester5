<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
    </padding>

    <Label text="Select Your Dates">
      <font>
         <Font name="System Bold" size="26.0" />
      </font></Label>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label prefWidth="200.0" text="Check-in Date" />
        <DatePicker fx:id="checkInPicker" prefWidth="200.0" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label prefWidth="200.0" text="Check-out Date" />
        <DatePicker fx:id="checkOutPicker" prefWidth="200.0" />
    </HBox>

    <Label fx:id="nightsLabel" text="" />
    <Label fx:id="errorLabel" text="" wrapText="true" />

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button onAction="#onDatesBack" prefHeight="40.0" prefWidth="90.0" text="Back" />
        <Button defaultButton="true" onAction="#onDatesNext" prefHeight="40.0" prefWidth="90.0" styleClass="next-btn" text="Next" />
    </HBox>
</VBox>
