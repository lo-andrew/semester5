<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="563.0" prefWidth="837.0" stylesheets="@styles.css" spacing="18.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
    </padding>

    <Label text="Your Details">
      <font>
         <Font name="System Bold" size="26.0" />
      </font></Label>
   <HBox alignment="CENTER" prefHeight="73.0" prefWidth="391.0" spacing="40.0">
      <children>
      
          <VBox spacing="4.0">
              <Label style="-fx-font-size: 14px;" text="First Name *" />
              <TextField fx:id="firstNameField" prefWidth="300.0" promptText="First name" />
              <Label fx:id="firstNameError" text="" />
          </VBox>
      
          <VBox spacing="4.0">
              <Label style="-fx-font-size: 14px;" text="Last Name *" />
              <TextField fx:id="lastNameField" prefWidth="300.0" promptText="Last name" />
              <Label fx:id="lastNameError" text="" />
          </VBox>
      </children>
   </HBox>
   <HBox alignment="CENTER" prefHeight="67.0" prefWidth="363.0" spacing="40.0">
      <children>
      
          <VBox spacing="4.0">
              <Label style="-fx-font-size: 14px;" text="Email Address *" />
              <TextField fx:id="emailField" prefWidth="300.0" promptText="you@example.com" />
              <Label fx:id="emailError" text="" />
          </VBox>
      
          <VBox spacing="4.0">
              <Label style="-fx-font-size: 14px;" text="Phone Number *" />
              <TextField fx:id="phoneField" prefWidth="300.0" promptText="e.g. 416-555-0100" />
              <Label fx:id="phoneError" text="" />
          </VBox>
      </children>
   </HBox>
   <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="40.0">
      <children>
      
          <VBox spacing="4.0">
              <Label style="-fx-font-size: 14px;" text="Address" />
              <TextField fx:id="addressField" prefWidth="300.0" promptText="Street address" />
              <Label fx:id="addressError" text="" />
          </VBox>
      
          <VBox spacing="4.0">
              <Label style="-fx-font-size: 14px;" text="Postal Code" />
              <TextField fx:id="postalCodeField" prefWidth="300.0" promptText="e.g. M1M 1M1" />
              <Label fx:id="postalCodeError" text="" />
          </VBox>
      </children>
   </HBox>

    <HBox alignment="CENTER" spacing="10.0">
        <RadioButton fx:id="loyaltyOptInRadio" onAction="#onLoyaltyOptInToggled" text="Enroll me in the Loyalty Program" />
        <Label fx:id="loyaltyStatusLabel" text="" wrapText="true" />
    </HBox>
   <Label text="Welcome to our Loyalty Program/ You are already a member of our Loyalty Program!" />

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button onAction="#onGuestDetailsBack" prefHeight="40.0" prefWidth="90.0" text="Back" />
        <Button onAction="#onGuestDetailsNext" prefHeight="40.0" prefWidth="90.0" styleClass="next-btn" text="Next" />
    </HBox>
</VBox>
