<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="18.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
    </padding>

    <Label text="Your Details">
      <font>
         <Font name="System Bold" size="26.0" />
      </font></Label>

    <VBox spacing="4.0">
        <Label style="-fx-font-size: 14px;" text="First Name *" />
        <TextField fx:id="firstNameField" promptText="First name" />
        <Label fx:id="firstNameError" text="" />
    </VBox>

    <VBox spacing="4.0">
        <Label style="-fx-font-size: 14px;" text="Last Name *" />
        <TextField fx:id="lastNameField" promptText="Last name" />
        <Label fx:id="lastNameError" text="" />
    </VBox>

    <VBox spacing="4.0">
        <Label style="-fx-font-size: 14px;" text="Phone Number *" />
        <TextField fx:id="phoneField" promptText="e.g. 416-555-0100" />
        <Label fx:id="phoneError" text="" />
    </VBox>

    <VBox spacing="4.0">
        <Label style="-fx-font-size: 14px;" text="Email Address *" />
        <TextField fx:id="emailField" promptText="you@example.com" />
        <Label fx:id="emailError" text="" />
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button onAction="#onGuestDetailsBack" prefHeight="40.0" prefWidth="90.0" text="Back" />
        <Button defaultButton="true" onAction="#onGuestDetailsNext" prefHeight="40.0" prefWidth="90.0" text="Next" />
    </HBox>
</VBox>
