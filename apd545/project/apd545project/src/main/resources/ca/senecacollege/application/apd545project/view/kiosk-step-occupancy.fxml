<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
    </padding>

    <Label text="How many guests?">
      <font>
         <Font name="System Bold" size="26.0" />
      </font></Label>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label prefWidth="200.0" text="Adults" />
        <Spinner fx:id="adultsSpinner" initialValue="1" max="20" min="1" prefWidth="100.0" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label prefWidth="200.0" text="Children" />
        <Spinner fx:id="childrenSpinner" initialValue="0" max="10" min="0" prefWidth="100.0" />
    </HBox>

    <Label fx:id="errorLabel" text="" wrapText="true" />

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button onAction="#onOccupancyBack" prefHeight="40.0" prefWidth="90.0" text="Back" />
        <Button defaultButton="true" onAction="#onOccupancyNext" prefHeight="40.0" prefWidth="90.0" styleClass="next-btn" text="Next" />
    </HBox>
</VBox>
