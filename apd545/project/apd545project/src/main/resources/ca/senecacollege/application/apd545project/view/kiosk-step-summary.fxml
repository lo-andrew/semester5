<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
    </padding>

    <Label text="Booking Summary">
      <font>
         <Font name="System Bold" size="26.0" />
      </font></Label>

    <Label fx:id="guestNameLabel" text="Guest: —" />
    <Label fx:id="datesLabel" text="Dates: —" />
    <Label fx:id="roomsLabel" text="Rooms: —" />
    <Label fx:id="addonsLabel" text="Add-ons: —" />

    <Separator />

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label prefWidth="200.0" text="Subtotal">
         <font>
            <Font name="System Italic" size="12.0" />
         </font></Label>
        <Label fx:id="subtotalLabel" text="—" />
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label prefWidth="200.0" text="Tax (13% HST)">
         <font>
            <Font name="System Italic" size="12.0" />
         </font></Label>
        <Label fx:id="taxLabel" text="—" />
    </HBox>
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label prefWidth="200.0" text="Loyalty Discount">
         <font>
            <Font name="System Italic" size="12.0" />
         </font></Label>
        <Label fx:id="loyaltyLabel" text="—" />
    </HBox>

    <Separator />

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label prefWidth="200.0" text="Estimated Total">
         <font>
            <Font name="System Bold" size="15.0" />
         </font></Label>
        <Label fx:id="totalLabel" text="—" />
    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <Button onAction="#onSummaryBack" prefHeight="40.0" prefWidth="90.0" text="Back" />
        <Button defaultButton="true" onAction="#onConfirm" prefHeight="40.0" prefWidth="112.0" text="Confirm Booking" />
    </HBox>
</VBox>
