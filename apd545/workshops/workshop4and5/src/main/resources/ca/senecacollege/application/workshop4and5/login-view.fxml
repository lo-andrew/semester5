<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>


<VBox alignment="CENTER" prefHeight="900.0" prefWidth="1200.0" spacing="5.0" stylesheets="@app.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.senecacollege.application.workshop4and5.controllers.LoginController">
   <children>
      <Label alignment="CENTER" prefHeight="48.0" prefWidth="408.0" styleClass="app-title" text="Nexus Consulting" />
      <Label styleClass="app-subtitle" text="Decision Support System">
         <VBox.margin>
            <Insets bottom="40.0" />
         </VBox.margin>
      </Label>
      <Label prefHeight="17.0" prefWidth="400.0" styleClass="field-label" text="Username" />
      <TextField fx:id="usernameField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="25.0" prefWidth="400.0">
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </TextField>
      <Label prefHeight="17.0" prefWidth="400.0" styleClass="field-label" text="Password" />
      <PasswordField fx:id="passwordField" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="25.0" prefWidth="400.0">
         <VBox.margin>
            <Insets bottom="30.0" />
         </VBox.margin>
      </PasswordField>
      <Label fx:id="statusLabel" styleClass="error-label">
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>
      <Button fx:id="loginBtn" mnemonicParsing="false" onAction="#handleLogin" prefHeight="48.0" prefWidth="108.0" styleClass="primary-button" text="Login" />
   </children>
</VBox>
