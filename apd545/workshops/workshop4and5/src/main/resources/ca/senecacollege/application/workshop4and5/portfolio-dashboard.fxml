<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="900.0" prefWidth="1200.0" stylesheets="@app.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.senecacollege.application.workshop4and5.controllers.DashboardController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0" styleClass="toolbar-bar" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="58.0" prefWidth="265.0">
               <children>
                  <Label styleClass="field-label" text="Search" />
                  <TextField fx:id="searchField" prefHeight="25.0" prefWidth="175.0" promptText="Filter by title..." />
               </children>
            </VBox>
            <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="58.0" prefWidth="100.0">
               <children>
                  <Label styleClass="field-label" text="Status" />
                  <ChoiceBox fx:id="statusFilterChoiceBox" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="28.0" prefWidth="150.0" />
               </children>
            </VBox>
         </children>
      </HBox>
   </top>
   <left>
      <ListView fx:id="projectListView" prefHeight="800.0" prefWidth="330.0" BorderPane.alignment="CENTER" />
   </left>
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" styleClass="card" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="47.0" prefWidth="940.0" spacing="20.0">
               <children>
                  <Label fx:id="projectTitleLabel" styleClass="section-title" text="Project Title" />
                  <Label fx:id="projectTypeLabel" styleClass="project-type-label" text="Type" />
                  <Label fx:id="totalCostLabel" styleClass="total-cost-label" text="Total Cost: $0.00" />
               </children>
            </HBox>
            <TableView fx:id="assignmentsTable" editable="true" prefHeight="612.0" prefWidth="940.0">
              <columns>
                <TableColumn fx:id="employeeNameColumn" prefWidth="230.0" text="Employee Name" />
                <TableColumn fx:id="roleColumn" prefWidth="230.0" text="Role" />
                <TableColumn fx:id="allocatedHoursColumn" prefWidth="230.0" text="Allocated Hours" />
                <TableColumn fx:id="costColumn" prefWidth="230.0" text="Cost" />
              </columns>
            </TableView>
            <Button fx:id="addTeamMemberBtn" mnemonicParsing="false" onAction="#handleAddTeamMember" styleClass="primary-button" text="Add Team Member" />
         </children>
      </VBox>
   </center>
</BorderPane>
