<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<SplitPane dividerPositions="0.5" prefHeight="900.0" prefWidth="1200.0" stylesheets="@app.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.senecacollege.application.workshop4and5.controllers.AllocatorController">
   <items>
      <VBox alignment="TOP_LEFT" prefHeight="200.0" prefWidth="100.0" spacing="8.0" styleClass="card">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label styleClass="section-title" text="New Assignment" />
            <Label styleClass="field-label" text="Skill Filter" />
            <ComboBox fx:id="skillFilterComboBox" prefWidth="220.0" promptText="All Skills" onAction="#handleSkillFilter"/>
            <Label styleClass="field-label" text="Employee" />
            <ComboBox fx:id="employeeComboBox" prefWidth="220.0" promptText="Select Employee" />
            <Label styleClass="field-label" text="Role" />
            <TextField fx:id="roleField" prefWidth="220.0" />
            <Label styleClass="field-label" text="New Hours" />
            <TextField fx:id="newHoursField" prefWidth="220.0" />
            <Label styleClass="field-label" text="Projected Load" />
            <Label fx:id="projectedLoadLabel" styleClass="projected-load-label" text="0 / 40 hrs" />
            <HBox spacing="10.0">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <children>
                  <Button fx:id="confirmBtn" mnemonicParsing="false" onAction="#handleConfirm" prefHeight="58.0" prefWidth="140.0" styleClass="primary-button" text="Confirm" />
                  <Button fx:id="cancelBtn" mnemonicParsing="false" onAction="#handleCancel" prefHeight="58.0" prefWidth="140.0" styleClass="secondary-button" text="Cancel" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="8.0" styleClass="card">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label styleClass="section-title" text="Current Workload" />
            <TableView fx:id="currentWorkloadTable" editable="true" prefHeight="820.0" prefWidth="566.0">
              <columns>
                <TableColumn fx:id="workloadProjectColumn" prefWidth="140.0" text="Project" />
                <TableColumn fx:id="workloadRoleColumn" prefWidth="140.0" text="Role" />
                <TableColumn fx:id="workloadHoursColumn" prefWidth="140.0" text="Allocated Hours" />
                <TableColumn fx:id="workloadCostColumn" prefWidth="140.0" text="Cost" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </items>
</SplitPane>
